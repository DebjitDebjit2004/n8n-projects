    {
      "parameters": {
        "jsCode": "const baseUrl = \"https://www.linkedin.com/jobs/search/?\";\n\nconst keyword = ($input.first().json.output || \"\").trim();\n\nconst location = $('On form submission').first().json['location'] || \"\";\nconst experienceLevel = $('On form submission').first().json['Experience Level'] || \"\";\nconst remote = $('On form submission').first().json['Work Mode'] || \"\";\nconst jobType = $('On form submission').first().json['Job Type'] || \"\";\n\nconst MIN_FILTERS = 2;\nconst MAX_FILTERS = 4;\n\n\n// -------- helpers --------\n\nfunction mapExperience(exp) {\n\tswitch (exp) {\n\t\tcase \"Internship\": return \"1\";\n\t\tcase \"Entry level\": return \"2\";\n\t\tcase \"Associate\": return \"3\";\n\t\tcase \"Mid-Senior level\": return \"4\";\n\t\tcase \"Director\": return \"5\";\n\t\tcase \"Executive\": return \"6\";\n\t\tdefault: return \"\";\n\t}\n}\n\nfunction mapRemote(r) {\n\tswitch (r) {\n\t\tcase \"On-Site\": return \"1\";\n\t\tcase \"Remote\": return \"2\";\n\t\tcase \"Hybrid\": return \"3\";\n\t\tdefault: return \"\";\n\t}\n}\n\nfunction mapJobType(t) {\n\tswitch (t) {\n\t\tcase \"Full-time\": return \"F\";\n\t\tcase \"Part-time\": return \"P\";\n\t\tcase \"Contract\": return \"C\";\n\t\tcase \"Temporary\": return \"T\";\n\t\tcase \"Internship\": return \"I\";\n\t\tdefault: return \"\";\n\t}\n}\n\n\n// -------- filter objects --------\n\nconst filters = [\n\t{\n\t\tkey: \"location\",\n\t\tvalue: location ? `location=${encodeURIComponent(location)}` : null\n\t},\n\t{\n\t\tkey: \"experience\",\n\t\tvalue: experienceLevel ? `f_E=${mapExperience(experienceLevel)}` : null\n\t},\n\t{\n\t\tkey: \"remote\",\n\t\tvalue: remote ? `f_WT=${mapRemote(remote)}` : null\n\t},\n\t{\n\t\tkey: \"jobType\",\n\t\tvalue: jobType ? `f_JT=${mapJobType(jobType)}` : null\n\t}\n];\n\n\n// -------- generate combinations --------\n\nconst results = [];\nconst unique = new Set();\nconst n = filters.length;\n\nfor (let mask = 1; mask < (1 << n); mask++) {\n\n\tconst usedFilters = [];\n\n\tfor (let i = 0; i < n; i++) {\n\t\tif (mask & (1 << i)) {\n\t\t\tif (filters[i].value) {\n\t\t\t\tusedFilters.push(filters[i]);\n\t\t\t}\n\t\t}\n\t}\n\n\tif (usedFilters.length < MIN_FILTERS || usedFilters.length > MAX_FILTERS) continue;\n\n\tlet url = baseUrl;\n\n\tif (keyword) {\n\t\turl += `&keywords=${encodeURIComponent(keyword)}`;\n\t}\n\n\tfor (const f of usedFilters) {\n\t\turl += `&${f.value}`;\n\t}\n\n\tif (!unique.has(url)) {\n\n\t\tunique.add(url);\n\n\t\tresults.push({\n\t\t\tjson: {\n\t\t\t\turl,\n\t\t\t\tappliedFilters: usedFilters.map(f => f.key)\n\t\t\t}\n\t\t});\n\t}\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
